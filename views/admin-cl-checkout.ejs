<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css">
    <link href="https://fonts.googleapis.com/css?family=Montserrat" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/payment.css">
    <style> 
    #confirmation-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: none;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.5);
        z-index: 1000; /* Ensure modal is above everything */
    }

    .modal-content {
        background-color: white;
        padding: 20px;
        border-radius: 8px;
        text-align: center;
        width: 300px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2); /* Add shadow for a better look */
        z-index: 1010; /* Ensure content is above background dim */
    }

    .modal-content button {
        margin: 10px;
    }

    /* Prevent background from being scrollable */
    body.modal-open {
        overflow: hidden;
    }
    </style>
    <!--admin-cl-checkout.ejs -->
</head>

<body>
    <!-- Navbar -->
    <nav>
        <div class="logo">
            <img src="/img/logonew100.png" alt="Logo">
        </div>
        <div class="nav-links">
            <a href="/" class="nav-item">Home</a>
            <a href="/about" class="nav-item">About</a>
            <a href="/checkout" class="nav-item">Checkout</a>
            <a href="/orders" class="nav-item">Orders</a>
        </div>
        <div>
            <a href="/cart" class="search-icon">
                <img src="/img/store1.svg" alt="Search" />
            </a>
            <a href="/profile" class="search-icon">
                <img src="/img/p2.png" alt="Profile">
            </a>
        </div>
    </nav>

    <main class="payment-page">
        <section class="payment-form dark">
            <div class="container">
                <div class="block-heading">
                    <h2 class="text-primary">Payment Checkout</h2>
                    <p>Review and confirm your order before making the payment.</p>
                    <!-- Display user_id here -->
                    <p><strong>User ID:</strong>
                        <%= clientId || userId %>
                    </p> <!-- Display clientId or userId -->
                </div>
                <form action="/admin/admin-cl-checkout/<%= clientId %>/confirm" method="POST">
                    <!-- Products Section -->
                    <div class="products shadow-sm rounded mb-4">
                        <h3 class="title">Order Summary</h3>
                        <% if (cartItems.length===0) { %>
                            <p class="text-center text-muted">Your cart is empty. Please add items to your cart.</p>
                            <% } else { %>
                                <% cartItems.forEach(item=> { %>
                                    <div class="item d-flex align-items-center">
                                        <p class="item-name mb-0 flex-grow-2 text-left">
                                            <%= item.product_name %> <!-- Product name -->
                                        </p>
                                        <p class="item-quantity mb-0 flex-grow-1 text-center">
                                            <%= item.quantity %> <!-- Quantity -->
                                        </p>

                                        <p class="price mb-0 flex-grow-1 text-righ">
                                            $<%= (parseFloat(item.price) * item.quantity).toFixed(2) %>
                                                <!-- Total price -->
                                        </p>
                                        <!-- Remove Button with confirmation -->
                                        <!-- <button class="remove-btn" data-item-id="<%= item.id %>">Remove</button> -->
                                    </div>
                                    <% }); %>
                                        <div class="total mt-3 text-center">
                                            <strong>Total: $<%= totalPrice.toFixed(2) %></strong>
                                        </div>
                                        <% } %>
                    </div>

                    <!-- Additional Payment Options Section -->
                    <div class="new-section shadow-sm rounded mb-4 p-3">
                        <h4 class="mb-3">Additional Payment Options</h4>
                        <button type="button" class="btn btn-info btn-block">
                            <i class="fab fa-paypal"></i> Pay with PayPal
                        </button>
                        <!-- Button -->
                        <button type="button" class="btn btn-warning btn-block mt-2" id="payWalletBtn" tabindex="0">
                            <i class="fas fa-wallet"></i> Pay with Wallet
                        </button>

                        <!-- Modal -->
                        <div id="confirmation-modal">
                            <div class="modal-content">
                                <h4>Confirm Wallet Payment</h4>
                                <p>Are you sure you want to proceed with payment using the wallet?</p>
                                <button id="confirm-payment" class="btn btn-success">Yes, Confirm</button>
                                <button id="cancel-payment" class="btn btn-danger">Cancel</button>
                            </div>
                        </div>
                    </div>

                    <!-- Card Details Section -->
                    <div class="card-details shadow-sm rounded p-4">
                        <h3 class="title mb-3">Payment Details</h3>
                        <div class="row">
                            <div class="form-group col-sm-7">
                                <label for="card-holder">Card Holder</label>
                                <input id="card-holder" type="text" name="cardHolder" class="form-control"
                                    placeholder="Card Holder" required>
                            </div>
                            <div class="form-group col-sm-5">
                                <label for="">Expiration Date</label>
                                <div class="input-group">
                                    <input type="text" name="expMonth" class="form-control" placeholder="MM" required>
                                    <span class="date-separator">/</span>
                                    <input type="text" name="expYear" class="form-control" placeholder="YY" required>
                                </div>
                            </div>
                            <div class="form-group col-sm-12">
                                <label for="card-number">Card Number</label>
                                <input id="card-number" type="text" name="cardNumber" class="form-control"
                                    placeholder="Card Number" required>
                            </div>
                            <div class="form-group col-sm-12">
                                <label for="cvc">CVC</label>
                                <input id="cvc" type="text" name="cvc" class="form-control" placeholder="CVC" required>
                            </div>
                        </div>
                        <a href="/admin/client-cart/<%= clientId %>" class="btn btn-outline-primary btn-block mt-3">
                            <i class="fas fa-shopping-cart"></i> Back to Cart
                        </a>

                        <button type="submit" class="btn btn-primary btn-block mt-3">Confirm Order</button>
                    </div>
                </form>
            </div>
        </section>
    </main>

    <!-- Confirmation Modal for Item Removal -->
    <div id="confirmation-modal" class="modal" style="display: none;">
        <div class="modal-content">
            <p>Are you sure you want to remove this item from the cart?</p>
            <button id="confirm-remove">Yes</button>
            <button id="cancel-remove">No</button>
        </div>
    </div>

    <footer class="footer_container">
        <div class="social-icons">
            <a href="#"><i class="fab fa-facebook"></i></a>
            <a href="#"><i class="fab fa-instagram"></i></a>
            <a href="#"><i class="fab fa-twitter"></i></a>
            <a href="#"><i class="fab fa-youtube"></i></a>
            <a href="#"><i class="fab fa-google-drive"></i></a>
            <a href="#"><i class="fab fa-linkedin-in"></i></a>
        </div>
        <div class="footer_bottom">
            <p>© 2024 Barca Museum. Designed by <span class="designer">Barca Zone</span></p>
        </div>
    </footer>
    <script src="/js/ad-cl-checkout.js"></script>
    <script></script>

</body>

</html>